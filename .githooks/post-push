#!/bin/bash

BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null | tr -cd '[:alnum:]/_.-')

# Skip pushes to main/master
if [[ "$BRANCH" == "main" || "$BRANCH" == "master" ]]; then
  exit 0
fi

command -v gh >/dev/null 2>&1 || { echo "gh CLI not found, skipping PR prompt"; exit 0; }
command -v claude >/dev/null 2>&1 || { echo "claude CLI not found, skipping PR prompt"; exit 0; }

echo ""
read -rp "Create/update PR with Claude summary? (y/n): " answer
[[ "$answer" != "y" ]] && exit 0

PROMPT_STEPS="Steps:
1. Run: git log main...HEAD --oneline
2. Run: git diff main...HEAD --stat
3. Generate: concise summary of changes, and a mermaid diagram of affected components/files
4. Fill the .github/pull_request_template.md sections (Summary, Changes, Architecture, Test Plan)"

PR_NUMBER=$(gh pr view "$BRANCH" --json number --jq '.number' 2>/dev/null || true)

# Validate PR_NUMBER is a positive integer (defense-in-depth)
if [[ -n "$PR_NUMBER" ]] && ! [[ "$PR_NUMBER" =~ ^[0-9]+$ ]]; then
  echo "Unexpected PR number format, aborting."
  exit 1
fi

if [[ -n "$PR_NUMBER" ]]; then
  echo "-> Updating PR #$PR_NUMBER..."
  claude -p "Update PR #${PR_NUMBER} for branch ${BRANCH}. ${PROMPT_STEPS}
5. Run: gh pr edit ${PR_NUMBER} --body '<filled template content>'" \
    || echo "Claude failed to update PR. Run manually: gh pr edit ${PR_NUMBER}"
else
  echo "-> Creating PR for branch ${BRANCH}..."
  claude -p "Create a PR for branch ${BRANCH}. ${PROMPT_STEPS}
5. Run: gh pr create --title '<short title from commits>' --body '<filled template content>'" \
    || echo "Claude failed to create PR. Run manually: gh pr create"
fi
