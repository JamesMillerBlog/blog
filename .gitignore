# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
.pnp
.pnp.*

# temporary files
temp/

# local docker overrides (contain host paths)
docker-compose.override.yml

# testing
coverage

# next.js
.next/
out/

# production
build

# misc
.DS_Store
*.pem

# Claude Code plugin runtime directories
.playwright-mcp/
.superpowers/

# OpenCode plugin runtime
.opencode/node_modules/
.opencode/bun.lock

# Claude Code local settings (machine-specific paths)
.claude/settings.local.json

# AI review stamp (local only — written by /pre-push-review command)
.claude/.review-stamp

# debug
npm-debug.log*

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo
next-env.d.ts

# content
web/_posts/

# terraform
infrastructure/**/.terraform/*
infrastructure/**/*.tfstate
infrastructure/**/*.tfstate.*
infrastructure/**/crash.log
infrastructure/**/crash.*.log
infrastructure/**/*.tfvars
!infrastructure/vars/**/*.tfvars
infrastructure/**/override.tf
infrastructure/**/override.tf.json
infrastructure/**/*_override.tf
infrastructure/**/*_override.tf.json
infrastructure/**/.terraformrc
infrastructure/**/terraform.rc

# .envrc holds local secrets (API tokens, env vars).
# backend.hcl holds account-specific Terraform backend config.
# Both are gitignored so the repo is reusable as a public reference.
# Copy the .example files and fill in your values.
.envrc
infrastructure/vars/backend.hcl
