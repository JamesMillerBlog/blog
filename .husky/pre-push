#!/bin/bash
set -eo pipefail

# Run a fast local secret scan before heavier checks when available.
./scripts/pre-push-secret-scan.sh

# Run tests with a 2-minute timeout to prevent indefinite hangs
if command -v timeout > /dev/null 2>&1; then
  timeout 120 pnpm test
else
  pnpm test
fi

# Run AI review loop — iterates until clean or blocks push
bash scripts/pre-push-iterate.sh
