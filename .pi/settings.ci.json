{
  "defaultProvider": "opencode-go",
  "defaultModel": "opencode-go/deepseek-v4-pro",
  "skills": [".agents/skills"],
  "prompts": [".pi/prompts"],
  "enabledModels": ["opencode-go/*"],
  "hideThinkingBlock": true,
  "quietStartup": true,
  "compaction": {
    "reserveTokens": 16384,
    "keepRecentTokens": 32000
  },
  "branchSummary": {
    "reserveTokens": 8192
  },
  "retry": {
    "maxRetries": 5,
    "provider": {
      "timeoutMs": 120000,
      "maxRetries": 5,
      "maxRetryDelayMs": 60000
    }
  },
  "packages": [
    "npm:pi-lens",
    "npm:pi-multiagent",
    "npm:pi-gh-cli"
  ]
}
