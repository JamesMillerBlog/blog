{
  "defaultProvider": "opencode-go",
  "defaultModel": "deepseek-v4-pro",
  "skills": [
    ".agents/skills"
  ],
  "prompts": [
    ".pi/prompts"
  ],
  "agents": [
    ".pi/agents"
  ],
  "enabledModels": [
    "opencode-go/*"
  ],
  "compaction": {
    "reserveTokens": 16384,
    "keepRecentTokens": 32000
  },
  "retry": {
    "maxRetries": 5,
    "provider": {
      "timeoutMs": 120000,
      "maxRetries": 5,
      "maxRetryDelayMs": 60000
    }
  },
  "branchSummary": {
    "reserveTokens": 8192
  },
  "packages": [
    "npm:pi-lens",
    "npm:pi-multiagent",
    "npm:pi-gh-cli",
    "npm:pi-powerline-footer",
    "npm:pi-caveman",
    "npm:@demigodmode/pi-web-agent"
  ],
  "hideThinkingBlock": true
}