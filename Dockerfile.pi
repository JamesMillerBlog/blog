FROM node:22.19.0-slim

RUN apt-get update && apt-get install -y python3 git curl ca-certificates tzdata && rm -rf /var/lib/apt/lists/*

ENV TZ=Europe/London

RUN npm install -g --ignore-scripts @earendil-works/pi-coding-agent pnpm@9.15.9

RUN useradd -m -s /bin/bash pi

# Pre-install pi extensions into the pi user's home so they don't
# need to be fetched at runtime (which fails due to permissions).
RUN mkdir -p /home/pi/.pi/agent/npm /home/pi/.npm && chown -R pi:pi /home/pi/.pi /home/pi/.npm
COPY --chown=pi:pi docker/pi-settings.json /home/pi/.pi/agent/settings.json

USER pi
RUN npm install \
      --prefix /home/pi/.pi/agent/npm \
      --no-save \
      pi-multiagent@0.9.0 \
      pi-gh-cli@0.2.4 \
      pi-powerline-footer@0.5.4
USER root
RUN rm -rf /home/pi/.npm/_cacache && chown -R pi:pi /home/pi/.npm

WORKDIR /workspace

USER pi

ENTRYPOINT ["pi", "--agent-team-subagent-skills", "disabled"]
