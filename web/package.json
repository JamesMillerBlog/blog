{
  "name": "web",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "../scripts/fix-em-dashes.sh && prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "precommit": "lint-staged",
    "health": "cd .. && ./scripts/code-health-check.sh --quick",
    "health:full": "cd .. && ./scripts/code-health-check.sh",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "audit:security": "bash ../scripts/security-audit-run.sh; exit 0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{js,jsx,mjs,json,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@sentry/nextjs": "^10",
    "classnames": "^2.5.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "fuse.js": "^7.4.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "next": "latest",
    "next-mdx-remote": "^5.0.0",
    "posthog-js": "^1.378.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-pretty-code": "^0.14.3",
    "shiki": "^4.1.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@storybook/nextjs-vite": "9.1.20",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "cspell": "^10.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "jscpd": "^4.2.4",
    "jsdom": "^29.1.1",
    "knip": "^6.15.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "storybook": "^9.1.20",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
