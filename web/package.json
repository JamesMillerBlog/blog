{
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "precommit": "lint-staged",
    "health": "cd .. && ./scripts/code-health-check.sh --quick",
    "health:full": "cd .. && ./scripts/code-health-check.sh"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{js,jsx,mjs,json,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "next": "latest",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-pretty-code": "^0.14.3",
    "shiki": "^4.0.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.0.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2.0.0",
    "cspell": "^10.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "jscpd": "^4.2.4",
    "knip": "^6.14.2",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.10",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  }
}
